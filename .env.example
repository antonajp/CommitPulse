# gitrx PostgreSQL connection configuration
# Copy this file to .env and update values before use.
# IMPORTANT: Never commit .env to version control.
#
# Ticket: IQS-846

# Database host — use "localhost" for local development.
DB_HOST=localhost

# PostgreSQL port exposed on the host machine.
DB_PORT=5433

# Database name.
DB_NAME=gitrx

# Database user.
DB_USER=gitrx_admin

# Database password — CHANGE THIS before use.
DB_PASSWORD=change_me_before_use
